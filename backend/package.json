{
  "name": "matschema-backend",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:cleanup": "jest --runInBand test/cleanup-*.test.js",
    "test:coverage": "jest --coverage --coverageReporters=text-summary --coverageReporters=lcov",
    "cleanup": "node scripts/cleanup.js",
    "lint": "eslint . --ext .js --max-warnings=0",
    "build": "node -e \"console.log('No build step yet')\"",
    "prepare": "husky install",
    "commitlint": "commitlint --edit $1"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "eslint": "^9.36.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.6",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  },
  "lint-staged": {
    "*.{js,json}": [
      "eslint --fix",
      "git add"
    ]
  }
}
